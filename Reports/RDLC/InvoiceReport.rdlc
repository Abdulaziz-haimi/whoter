                <TablixCell><CellContents><Textbox Name="hdrInvoiceNo"><CanGrow>true</CanGrow><Paragraphs><Paragraph><TextRuns><TextRun><Value>رقم الفاتورة</Value><Style><FontFamily>Tahoma</FontFamily><FontSize>9pt</FontSize><FontWeight>Bold</FontWeight><Color>White</Color></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><Style><Border><Color>#D7DFE8</Color><Style>Solid</Style></Border><BackgroundColor>#0057B7</BackgroundColor><VerticalAlign>Middle</VerticalAlign><Direction>RTL</Direction><PaddingLeft>2pt</PaddingLeft><PaddingRight>2pt</PaddingRight><PaddingTop>2pt</PaddingTop><PaddingBottom>2pt</PaddingBottom></Style></Textbox></CellContents></TablixCell>
                <TablixCell><CellContents><Textbox Name="hdrSubscriber"><CanGrow>true</CanGrow><Paragraphs><Paragraph><TextRuns><TextRun><Value>المشترك</Value><Style><FontFamily>Tahoma</FontFamily><FontSize>9pt</FontSize><FontWeight>Bold</FontWeight><Color>White</Color></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><Style><Border><Color>#D7DFE8</Color><Style>Solid</Style></Border><BackgroundColor>#0057B7</BackgroundColor><VerticalAlign>Middle</VerticalAlign><Direction>RTL</Direction><PaddingLeft>2pt</PaddingLeft><PaddingRight>2pt</PaddingRight><PaddingTop>2pt</PaddingTop><PaddingBottom>2pt</PaddingBottom></Style></Textbox></CellContents></TablixCell>
                <TablixCell><CellContents><Textbox Name="hdrMeter"><CanGrow>true</CanGrow><Paragraphs><Paragraph><TextRuns><TextRun><Value>العداد</Value><Style><FontFamily>Tahoma</FontFamily><FontSize>9pt</FontSize><FontWeight>Bold</FontWeight><Color>White</Color></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><Style><Border><Color>#D7DFE8</Color><Style>Solid</Style></Border><BackgroundColor>#0057B7</BackgroundColor><VerticalAlign>Middle</VerticalAlign><Direction>RTL</Direction><PaddingLeft>2pt</PaddingLeft><PaddingRight>2pt</PaddingRight><PaddingTop>2pt</PaddingTop><PaddingBottom>2pt</PaddingBottom></Style></Textbox></CellContents></TablixCell>
                <TablixCell><CellContents><Textbox Name="hdrStatus"><CanGrow>true</CanGrow><Paragraphs><Paragraph><TextRuns><TextRun><Value>الحالة</Value><Style><FontFamily>Tahoma</FontFamily><FontSize>9pt</FontSize><FontWeight>Bold</FontWeight><Color>White</Color></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><Style><Border><Color>#D7DFE8</Color><Style>Solid</Style></Border><BackgroundColor>#0057B7</BackgroundColor><VerticalAlign>Middle</VerticalAlign><Direction>RTL</Direction><PaddingLeft>2pt</PaddingLeft><PaddingRight>2pt</PaddingRight><PaddingTop>2pt</PaddingTop><PaddingBottom>2pt</PaddingBottom></Style></Textbox></CellContents></TablixCell>
                <TablixCell><CellContents><Textbox Name="hdrNotes"><CanGrow>true</CanGrow><Paragraphs><Paragraph><TextRuns><TextRun><Value>الملاحظات</Value><Style><FontFamily>Tahoma</FontFamily><FontSize>9pt</FontSize><FontWeight>Bold</FontWeight><Color>White</Color></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><Style><Border><Color>#D7DFE8</Color><Style>Solid</Style></Border><BackgroundColor>#0057B7</BackgroundColor><VerticalAlign>Middle</VerticalAlign><Direction>RTL</Direction><PaddingLeft>2pt</PaddingLeft><PaddingRight>2pt</PaddingRight><PaddingTop>2pt</PaddingTop><PaddingBottom>2pt</PaddingBottom></Style></Textbox></CellContents></TablixCell>
                <TablixCell><CellContents><Textbox Name="hdrConsumption"><CanGrow>true</CanGrow><Paragraphs><Paragraph><TextRuns><TextRun><Value>الاستهلاك</Value><Style><FontFamily>Tahoma</FontFamily><FontSize>9pt</FontSize><FontWeight>Bold</FontWeight><Color>White</Color></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><Style><Border><Color>#D7DFE8</Color><Style>Solid</Style></Border><BackgroundColor>#0057B7</BackgroundColor><VerticalAlign>Middle</VerticalAlign><Direction>RTL</Direction><PaddingLeft>2pt</PaddingLeft><PaddingRight>2pt</PaddingRight><PaddingTop>2pt</PaddingTop><PaddingBottom>2pt</PaddingBottom></Style></Textbox></CellContents></TablixCell>
                <TablixCell><CellContents><Textbox Name="hdrUnitPrice"><CanGrow>true</CanGrow><Paragraphs><Paragraph><TextRuns><TextRun><Value>سعر الوحدة</Value><Style><FontFamily>Tahoma</FontFamily><FontSize>9pt</FontSize><FontWeight>Bold</FontWeight><Color>White</Color></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><Style><Border><Color>#D7DFE8</Color><Style>Solid</Style></Border><BackgroundColor>#0057B7</BackgroundColor><VerticalAlign>Middle</VerticalAlign><Direction>RTL</Direction><PaddingLeft>2pt</PaddingLeft><PaddingRight>2pt</PaddingRight><PaddingTop>2pt</PaddingTop><PaddingBottom>2pt</PaddingBottom></Style></Textbox></CellContents></TablixCell>
