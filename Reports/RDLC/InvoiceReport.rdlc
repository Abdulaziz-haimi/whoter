<?xml version="1.0" encoding="utf-8"?>
<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2008/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner">
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="InvoiceDataSource">
      <ConnectionProperties>
        <DataProvider>System.Data.DataSet</DataProvider>
        <ConnectString />
      </ConnectionProperties>
      <rd:DataSourceID>9d7a1111-2222-3333-4444-555555555555</rd:DataSourceID>
    </DataSource>
  </DataSources>

  <DataSets>
    <DataSet Name="dsInvoices">
      <Fields>
        <Field Name="Dt1"><DataField>Dt1</DataField><rd:TypeName>System.DateTime</rd:TypeName></Field>
        <Field Name="Col1"><DataField>Col1</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="Col2"><DataField>Col2</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="Col3"><DataField>Col3</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="Col4"><DataField>Col4</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="Col5"><DataField>Col5</DataField><rd:TypeName>System.String</rd:TypeName></Field>
        <Field Name="Num1"><DataField>Num1</DataField><rd:TypeName>System.Decimal</rd:TypeName></Field>
        <Field Name="Num2"><DataField>Num2</DataField><rd:TypeName>System.Decimal</rd:TypeName></Field>
        <Field Name="Num3"><DataField>Num3</DataField><rd:TypeName>System.Decimal</rd:TypeName></Field>
        <Field Name="Num4"><DataField>Num4</DataField><rd:TypeName>System.Decimal</rd:TypeName></Field>
        <Field Name="Num5"><DataField>Num5</DataField><rd:TypeName>System.Decimal</rd:TypeName></Field>
        <Field Name="RowId"><DataField>RowId</DataField><rd:TypeName>System.Int32</rd:TypeName></Field>
        <Field Name="RefId1"><DataField>RefId1</DataField><rd:TypeName>System.Int32</rd:TypeName></Field>
        <Field Name="RefId2"><DataField>RefId2</DataField><rd:TypeName>System.Int32</rd:TypeName></Field>
      </Fields>
      <Query>
        <DataSourceName>InvoiceDataSource</DataSourceName>
        <CommandText />
      </Query>
    </DataSet>
  </DataSets>

  <ReportParameters>
    <ReportParameter Name="pReportTitle"><DataType>String</DataType><Prompt>pReportTitle</Prompt><AllowBlank>true</AllowBlank></ReportParameter>
    <ReportParameter Name="pFromDate"><DataType>String</DataType><Prompt>pFromDate</Prompt><AllowBlank>true</AllowBlank></ReportParameter>
    <ReportParameter Name="pToDate"><DataType>String</DataType><Prompt>pToDate</Prompt><AllowBlank>true</AllowBlank></ReportParameter>
    <ReportParameter Name="pPrintedBy"><DataType>String</DataType><Prompt>pPrintedBy</Prompt><AllowBlank>true</AllowBlank></ReportParameter>
    <ReportParameter Name="pPrintedAt"><DataType>String</DataType><Prompt>pPrintedAt</Prompt><AllowBlank>true</AllowBlank></ReportParameter>
  </ReportParameters>

  <Body>
    <ReportItems>
      <Textbox Name="txtReportTitle">
        <CanGrow>true</CanGrow>
        <KeepTogether>true</KeepTogether>
        <Paragraphs>
          <Paragraph>
            <TextRuns>
              <TextRun>
                <Value>=IIF(Parameters!pReportTitle.Value = "", "تقرير الفواتير", Parameters!pReportTitle.Value)</Value>
                <Style><FontFamily>Tahoma</FontFamily><FontSize>16pt</FontSize><FontWeight>Bold</FontWeight></Style>
              </TextRun>
            </TextRuns>
            <Style><TextAlign>Center</TextAlign></Style>
          </Paragraph>
        </Paragraphs>
        <Top>0.15in</Top>
        <Left>0.15in</Left>
        <Height>0.35in</Height>
        <Width>10.9in</Width>
        <Style><Direction>RTL</Direction><PaddingLeft>2pt</PaddingLeft><PaddingRight>2pt</PaddingRight><PaddingTop>2pt</PaddingTop><PaddingBottom>2pt</PaddingBottom></Style>
      </Textbox>

      <Textbox Name="txtPeriod">
        <CanGrow>true</CanGrow>
        <KeepTogether>true</KeepTogether>
        <Paragraphs>
          <Paragraph>
            <TextRuns>
              <TextRun>
                <Value>="الفترة: من " &amp; Parameters!pFromDate.Value &amp; " إلى " &amp; Parameters!pToDate.Value</Value>
                <Style><FontFamily>Tahoma</FontFamily><FontSize>10pt</FontSize></Style>
              </TextRun>
            </TextRuns>
            <Style><TextAlign>Center</TextAlign></Style>
          </Paragraph>
        </Paragraphs>
        <Top>0.55in</Top>
        <Left>0.15in</Left>
        <Height>0.25in</Height>
        <Width>10.9in</Width>
        <Style><Direction>RTL</Direction><PaddingLeft>2pt</PaddingLeft><PaddingRight>2pt</PaddingRight><PaddingTop>2pt</PaddingTop><PaddingBottom>2pt</PaddingBottom></Style>
      </Textbox>

      <Textbox Name="txtPrintedMeta">
        <CanGrow>true</CanGrow>
        <KeepTogether>true</KeepTogether>
        <Paragraphs>
          <Paragraph>
            <TextRuns>
              <TextRun>
                <Value>="طبع بواسطة: " &amp; Parameters!pPrintedBy.Value &amp; "    |    تاريخ الطباعة: " &amp; Parameters!pPrintedAt.Value</Value>
                <Style><FontFamily>Tahoma</FontFamily><FontSize>8.5pt</FontSize><Color>#555555</Color></Style>
              </TextRun>
            </TextRuns>
            <Style><TextAlign>Center</TextAlign></Style>
          </Paragraph>
        </Paragraphs>
        <Top>0.86in</Top>
        <Left>0.15in</Left>
        <Height>0.22in</Height>
        <Width>10.9in</Width>
        <Style><Direction>RTL</Direction><PaddingLeft>2pt</PaddingLeft><PaddingRight>2pt</PaddingRight><PaddingTop>2pt</PaddingTop><PaddingBottom>2pt</PaddingBottom></Style>
      </Textbox>

