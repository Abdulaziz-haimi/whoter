                <TablixCell><CellContents><Textbox Name="txtConsumption"><CanGrow>true</CanGrow><Paragraphs><Paragraph><TextRuns><TextRun><Value>=IIF(IsNothing(Fields!Num1.Value), "", FormatNumber(Fields!Num1.Value, 2))</Value><Style><FontFamily>Tahoma</FontFamily><FontSize>8.5pt</FontSize></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><Style><Border><Color>#D7DFE8</Color><Style>Solid</Style></Border><VerticalAlign>Middle</VerticalAlign><Direction>RTL</Direction><PaddingLeft>2pt</PaddingLeft><PaddingRight>2pt</PaddingRight><PaddingTop>2pt</PaddingTop><PaddingBottom>2pt</PaddingBottom></Style></Textbox></CellContents></TablixCell>
                <TablixCell><CellContents><Textbox Name="txtUnitPrice"><CanGrow>true</CanGrow><Paragraphs><Paragraph><TextRuns><TextRun><Value>=IIF(IsNothing(Fields!Num2.Value), "", FormatNumber(Fields!Num2.Value, 2))</Value><Style><FontFamily>Tahoma</FontFamily><FontSize>8.5pt</FontSize></Style></TextRun></TextRuns><Style><TextAlign>Center</TextAlign></Style></Paragraph></Paragraphs><Style><Border><Color>#D7DFE8</Color><Style>Solid</Style></Border><VerticalAlign>Middle</VerticalAlign><Direction>RTL</Direction><PaddingLeft>2pt</PaddingLeft><PaddingRight>2pt</PaddingRight><PaddingTop>2pt</PaddingTop><PaddingBottom>2pt</PaddingBottom></Style></Textbox></CellContents></TablixCell>
