      <section name="water3.Properties.Settings" type="System.Configuration.ClientSettingsSection, System, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" allowExeDefinition="MachineToLocalUser" requirePermission="false" />
    </sectionGroup>
  </configSections>
  <appSettings>
    <add key="ApiEnabled" value="true" />
    <add key="ApiScheme" value="https" />
    <add key="ApiHost" value="+" />
    <add key="ApiPort" value="8443" />
    <add key="DiscoveryEnabled" value="true" />
    <add key="DiscoveryPort" value="37020" />
    <add key="EnableDetailedErrors" value="false" />
    <add key="Authentication:PasswordMode" value="Sha256Hex" />
  </appSettings>
  <connectionStrings>
    <add name="WaterBillingDB" connectionString="Data Source=.;Initial Catalog=WaterBillingDB;Integrated Security=True;MultipleActiveResultSets=True;TrustServerCertificate=True" providerName="System.Data.SqlClient" />
    <add name="water3.Properties.Settings.WaterBillingDBConnectionString" connectionString="Data Source=.;Initial Catalog=WaterBillingDB;Integrated Security=True;MultipleActiveResultSets=True;TrustServerCertificate=True" providerName="System.Data.SqlClient" />
