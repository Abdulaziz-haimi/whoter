	<Body>
		<ReportItems>

			<Image Name="imgLogo">
				<Source>External</Source>
				<Value>=Parameters!pLogoPath.Value</Value>
				<Sizing>FitProportional</Sizing>
				<Top>0.2cm</Top>
				<Left>16.6cm</Left>
				<Height>1.6cm</Height>
				<Width>3.0cm</Width>
