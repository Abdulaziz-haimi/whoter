				<Left>0.2cm</Left>
				<Height>0.7cm</Height>
				<Width>19.4cm</Width>
				<Style />
			</Textbox>

			<Textbox Name="txtInfo">
				<CanGrow>true</CanGrow>
				<KeepTogether>true</KeepTogether>
				<Paragraphs>
					<Paragraph>
						<TextRuns>
							<TextRun>
								<Value>= "الفترة: من " &amp; Parameters!pFrom.Value &amp; " إلى " &amp; Parameters!pTo.Value &amp; "    |    " &amp; "طُبع بواسطة: " &amp; Parameters!pUser.Value &amp; "    |    " &amp; Format(Now(),"yyyy-MM-dd HH:mm")</Value>
								<Style>
									<FontFamily>Tahoma</FontFamily>
									<FontSize>9.5pt</FontSize>
								</Style>
							</TextRun>
						</TextRuns>
						<Style>
							<TextAlign>Right</TextAlign>
						</Style>
					</Paragraph>
				</Paragraphs>
				<Top>1.9cm</Top>
				<Left>0.2cm</Left>
				<Height>0.6cm</Height>
				<Width>19.4cm</Width>
				<Style />
			</Textbox>

